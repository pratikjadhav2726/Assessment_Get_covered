APP_NAME=Auth Snippet Discovery API
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

REQUEST_TIMEOUT_MS=20000
GOTO_TIMEOUT_MS=12000
DOM_SETTLE_TIMEOUT_MS=2000
MAX_SNIPPET_CHARS=6000
MAX_CONCURRENT_SCANS=5
MAX_REDIRECT_HOPS=5
RESULT_CACHE_TTL_SECONDS=90

JOB_RETENTION_SECONDS=900
JOB_CLEANUP_INTERVAL_SECONDS=30
IDEMPOTENCY_TTL_SECONDS=600

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# memory | redis
STATE_BACKEND=redis
REDIS_URL=redis://redis:6379/0

# Comma-separated list of allowed browser origins for CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1,https://assessment-get-covered.vercel.app
